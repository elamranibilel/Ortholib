<form action="{{ path('app_cabinet_delete', {'id': cabinet.id}) }}" onclick="event.stopPropagation();" method="POST" onsubmit="return confirm('Etes-vous sûr de vouloir supprimer ce cabinet ?')">
    <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ cabinet.id) }}">
        <button class="btn btn-danger">
            Supprimer
        </button>
    </form>
    