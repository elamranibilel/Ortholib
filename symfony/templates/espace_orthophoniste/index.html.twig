{% extends "base.html.twig" %} {% block title %}Espace Orthophoniste{% endblock
%} {% block body %}

<div class="container mt-5">
  <div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="text-primary fw-bold">
      {{ orthophoniste.nom }} {{ orthophoniste.prenom }}
    </h1>
  </div>

  <div class="container px-4 px-lg-5 mt-5">
    <div
      class="row gx-4 gx-lg-5 row-cols-1 row-cols-md-2 row-cols-lg-4 justify-content-center"
    >
      <div class="col mb-4">
        <a href="{{ path('app_planning') }}" class="text-decoration-none">
          <div class="card h-100 shadow-lg border-0 rounded-3 overflow-hidden">
            <div
              class="position-relative"
              style="height: 200px; background-color: #f8f9fa"
            >
              <img
                src="{{ asset('uploads/images/planning.jpg') }}"
                alt="Planning de {{ orthophoniste.nom }}"
                class="img-fluid w-100 h-100"
                style="object-fit: cover"
              />
              <div
                class="overlay position-absolute top-0 start-0 w-100 h-100 bg-dark bg-opacity-50 d-flex justify-content-center align-items-center opacity-0 transition-opacity"
              >
                <h5 class="text-white fw-bold">Voir le planning</h5>
              </div>
            </div>
            <div class="card-body text-center">
              <h5 class="fw-bolder text-dark">Planning</h5>
            </div>
          </div>
        </a>
      </div>
      <div class="col mb-4">
        <a
          href="{{ path('app_espace_orthophoniste_choixPatient') }}"
          class="text-decoration-none"
        >
          <div class="card h-100 shadow-lg border-0 rounded-3 overflow-hidden">
            <div
              class="position-relative"
              style="height: 200px; background-color: #f8f9fa"
            >
              <img
                src="{{ asset('uploads/images/audition.webp') }}"
                alt="Liste des Patients"
                class="img-fluid w-100 h-100"
                style="object-fit: cover"
              />
              <div
                class="overlay position-absolute top-0 start-0 w-100 h-100 bg-dark bg-opacity-50 d-flex justify-content-center align-items-center opacity-0 transition-opacity"
              >
                <h5 class="text-white fw-bold">Voir la liste</h5>
              </div>
            </div>
            <div class="card-body text-center">
              <h5 class="fw-bolder text-dark">Liste des Patients</h5>
            </div>
          </div>
        </a>
      </div>
      <div class="col mb-4">
        <a
          href="{{ path('app_espace_orthophoniste_choix') }}"
          class="text-decoration-none"
        >
          <div class="card h-100 shadow-lg border-0 rounded-3 overflow-hidden">
            <div
              class="position-relative"
              style="height: 200px; background-color: #f8f9fa"
            >
              <img
                src="{{ asset('uploads/images/exercices.png') }}"
                alt="Liste des Exercices"
                class="img-fluid w-100 h-100"
                style="object-fit: cover"
              />
              <div
                class="overlay position-absolute top-0 start-0 w-100 h-100 bg-dark bg-opacity-50 d-flex justify-content-center align-items-center opacity-0 transition-opacity"
              >
                <h5 class="text-white fw-bold">Voir la liste</h5>
              </div>
            </div>
            <div class="card-body text-center">
              <h5 class="fw-bolder text-dark">Liste des Exercices</h5>
            </div>
          </div>
        </a>
      </div>
      <div class="col mb-4">
        <a
          href="{{
            path('app_signification_index', { origin: 'SignificationOrtho' })
          }}"
          class="text-decoration-none"
        >
          <div class="card h-100 shadow-lg border-0 rounded-3 overflow-hidden">
            <div
              class="position-relative"
              style="height: 200px; background-color: #f8f9fa"
            >
              <img
                src="{{ asset('uploads/images/signification.jpg') }}"
                alt="Liste des Significations"
                class="img-fluid w-100 h-100"
                style="object-fit: cover"
              />
              <div
                class="overlay position-absolute top-0 start-0 w-100 h-100 bg-dark bg-opacity-50 d-flex justify-content-center align-items-center opacity-0 transition-opacity"
              >
                <h5 class="text-white fw-bold">Voir la liste</h5>
              </div>
            </div>
            <div class="card-body text-center">
              <h5 class="fw-bolder text-dark">Liste des Significations</h5>
            </div>
          </div>
        </a>
      </div>
    </div>
  </div>
  {% if patientsEnAttente|length > 0 %}
  <div class="mt-5">
    <h2 class="text-warning mb-3">Patients en attente de confirmation</h2>
    <ul class="list-group">
      {% for patient in patientsEnAttente %}
      <li
        class="list-group-item d-flex justify-content-between align-items-center"
      >
        {{ patient.nom }} {{ patient.prenom }}
        <a
          href="{{
            path('app_espace_orthophoniste_confirmation', { id: patient.id })
          }}"
          class="btn btn-sm btn-success"
        >
          Confirmer
        </a>
      </li>
      {% endfor %}
    </ul>
  </div>
  {% else %}
  <div class="alert alert-info mt-5">Aucun patient en attente.</div>
  {% endif %}
</div>

<style>
  .card:hover .overlay {
    opacity: 1;
  }

  .transition-opacity {
    transition: opacity 0.3s ease-in-out;
  }
</style>

{# Ajout Exercice Ajout Signification #} {% endblock %}
