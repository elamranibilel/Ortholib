{% extends 'base.html.twig' %}

{% block title %}EspaceOrthophonisteController!{% endblock %}

{% block body %}
<div class="container mt-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="text-primary">
            Gestion des patients
        </h1>
        {% if is_granted('ROLE_ADMIN') %}
        <a href="{{ path('app_patient_new') }}" class="btn btn-success">
            <i class="bi bi-plus-circle"></i>
            Ajouter un patient
        </a>
        {% endif %}
    </div>
    <div class="container px-4 px-lg-5 mt-5">
        <div class="row gx-4 gx-lg-5 row-cols-2 row-cols-md-3 row-cols-xl-4 justify-content-center">
            {% for patient in patients %}
            <div class="col mb-5">
                <div class="card h-100 shadow-sm">
                    <div class="d-flex justify-content-center align-items-center"
                        style="height: 200px; overflow: hidden; background-color: transparent;">
                        {% if patient.imagesPatient is not empty %}
                        {% for image in patient.imagesPatient %}
                        <img src="{{ asset('uploads/images/' ~ image.name) }}" alt="Photo de {{ patient.nom }}"
                            class="img-fluid" style="width: 100%; height: 100%; object-fit: cover;">
                        {% endfor %}
                        {% else %}
                        <p class="text-muted">
                            Aucune image disponible
                        </p>
                        {% endif %}
                    </div>
                    <!-- Informations du patient -->
                    <div class="card-body p-4 text-center">
                        <h5 class="fw-bolder">
                            {{ patient.nom }}
                            {{ patient.prenom }}
                        </h5>
                        <p class="text-muted">
                            {{ patient.ville }}
                        </p>
                        <p class="text-success fw-bold">
                            {{ patient.telephone }}
                        </p>
                    </div>
                    <div class="card-footer p-4 pt-0 border-top-0 bg-light">
                        <div class="text-center">
                            {% set origin = app.request.query.get('origin') %}
                            <div class="text-center">
                                {% if origin == 'ExercicePatient' %}
                                <a href="{{ path('app_espace_orthophoniste_exercices_patient', {'id': patient.id}) }}"
                                    class="btn btn-primary">
                                    Exercice
                                </a>
                                {% elseif origin == 'Espace' %}
                                <a href="{{ path('app_espace_orthophoniste_patient_show', {'id': patient.id}) }}"
                                    class="btn btn-outline-success">Espace</a>

                                {% else %}
                                <a href="{{ path('app_patient_show', { id: patient.id }) }}" class="btn btn-dark">
                                    Voir les détails
                                </a>
                                {% endif %}
                            </div>
                            {# <a href="{{ path('app_espace_orthophoniste_exercices_patient', { id: patient.id }) }}"
                                class="btn btn-primary">Exercice</a>
                            {% elseif app.request.get('_route') == 'app_espace_orthophoniste' %}
                            <a class="btn btn-dark mt-auto" href="{{ path('app_patient_show', { id: patient.id }) }}">
                                Voir les détails
                            </a>
                            {% endif %} #}

                            {# <p>Route actuelle : {{ app.request.get('_route') }}</p> #}
                        </div>
                    </div>
                </div>
            </div>
            {% else %}
            <p class="text-center text-muted">
                <em>
                    Aucun patient trouvé.
                </em>
            </p>
            {% endfor %}
        </div>
    </div>
    <!-- Pagination -->
    <div class="d-flex justify-content-center mt-4">
        {{ knp_pagination_render(patients) }}
    </div>
</div>
{% endblock %}