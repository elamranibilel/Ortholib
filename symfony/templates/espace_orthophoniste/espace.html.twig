{% extends "base.html.twig" %} {% block title %}Espace {% endblock %} {% block
body %}
<div class="container mt-5">
  <h1 class="mb-4">
    Discussion avec
    {{ patient.nom }}
    {{ patient.prenom }}
  </h1>

  <h2>Commentaires :</h2>

  {% for c in commentaires %}
  <div class="card mb-3">
    <div class="card-header d-flex justify-content-between">
      <strong>{{ c.auteur.nom }} {{ c.auteur.prenom }}</strong>
      <span class="text-muted">{{ c.roleAuteur }}</span>
    </div>
    <div class="card-body">
      <p class="card-text">{{ c.texte | raw }}</p>
    </div>
    <div class="card-footer text-muted d-flex justify-content-between">
      <span
        >Destinataire:
        {{ c.destinataire.nom }}
        {{ c.destinataire.prenom }}</span
      >
      <span>{{ c.roleDestinataire }}</span>
    </div>
  </div>
  {% endfor %}

  <!-- Formulaire de réponse -->
  <div class="card mt-4">
    <div class="card-header">
      <h5>Répondre :</h5>
    </div>
    <div class="card-body">
      <form
        action="{{
          path('app_espace_orthophoniste_patient_show', { id: patient.id })
        }}"
        method="POST"
      >
        {{ form_start(form) }}
        <div class="mb-3">
          {{ form_label(form.texte, "Votre réponse") }}
          {{ form_row(form.texte, {'attr': {'class': 'form-control'}}) }}
        </div>
        <button type="submit" class="btn btn-primary">Envoyer</button>
        {{ form_end(form) }}
      </form>
    </div>
  </div>
</div>
{% endblock %}
