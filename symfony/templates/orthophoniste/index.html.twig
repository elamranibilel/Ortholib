{% extends 'base.html.twig' %} {% block title %} Liste des orthophonistes {%
endblock %} {% block body %}
<div class="container px-4 px-lg-5 mt-5">
  <div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="text-primary">Gestion des orthophonistes</h1>
    {% if is_granted('ROLE_ADMIN') %}
    <a href="{{ path('app_orthophoniste_new') }}" class="btn btn-success">
      <i class="bi bi-plus-circle"></i>
      Ajouter un orthophoniste
    </a>
    {% endif %}
  </div>

  <div class="d-flex align-items-center flex-wrap gap-2">
    <a href="{{ path('app_orthophoniste_surdite') }}" class="btn btn-primary"
      >Surdité</a
    >
    <a
      href="{{ path('app_orthophoniste_communication') }}"
      class="btn btn-primary"
      >Communication</a
    >
    <a href="{{ path('app_orthophoniste_ecriture') }}" class="btn btn-primary"
      >Ecriture</a
    >

    {% if app.request.get('_route') in ['app_orthophoniste_surdite',
    'app_orthophoniste_communication', 'app_orthophoniste_ecriture'] %}
    <a href="{{ path('app_orthophoniste') }}" class="btn btn-danger">Retour</a>
    {% endif %}

    {{ form_start(form, {'attr': {'class': 'd-flex'}}) }}
    <div class="input-group" style="max-width: 400px">
      <label for="search_query" class="visually-hidden"
        >Rechercher un orthophoniste</label
      >
      {{
        form_widget(form.query, {
          attr: {
            class: "form-control",
            placeholder: "Rechercher un orthophoniste",
          }
        })
      }}
      <button type="submit" class="btn btn-primary">
        <i class="fas fa-search"></i>
        Rechercher
      </button>
    </div>
    {{ form_end(form) }}
  </div>

  <br />

  <!-- Grille des orthophonistes -->
  <div
    class="row gx-4 gx-lg-5 row-cols-2 row-cols-md-3 row-cols-xl-4 justify-content-center"
  >
    {% for orthophoniste in orthophonistes %}
    <div class="col mb-5">
      <div class="card h-100 shadow-sm">
        <!-- Image de l'orthophoniste -->
        <div
          class="d-flex justify-content-center align-items-center"
          style="height: 200px; overflow: hidden"
        >
          {% if orthophoniste.imagesOrthophoniste is not empty %} {% for image
          in orthophoniste.imagesOrthophoniste %}
          <img
            src="{{ asset('uploads/images/' ~ image.name) }}"
            alt="Photo de {{ orthophoniste.nom }}"
            class="img-fluid"
            style="width: 100%; height: 100%; object-fit: cover"
          />
          {% endfor %} {% else %}
          <p class="text-muted">Aucune image disponible</p>
          {% endif %}
        </div>

        <!-- Détails de l'orthophoniste -->
        <div class="card-body p-4">
          <div class="text-center">
            <h5 class="fw-bolder">{{ orthophoniste.nom }}</h5>
            <p class="text-muted">{{ orthophoniste.ville }}</p>
            <p class="text-success fw-bold">{{ orthophoniste.email }}</p>
          </div>
        </div>

        <!-- Actions -->
        <div class="card-footer p-4 pt-0 border-top-0 bg-light">
          <div class="text-center">
            {% if is_granted('ROLE_PATIENT') %} {% if app.user.choixOrtho and
            app.user.choixOrtho.id == orthophoniste.id %} {% if not
            app.user.isConfirmed %}
            <span class="badge bg-warning text-dark mt-2"
              >En attente de confirmation</span
            >
            {% else %}
            <a
              class="btn btn-dark mt-auto"
              href="{{
                path('app_orthophoniste_compte_show', {
                  id: orthophoniste.id,
                  origin: 'IndexOrthophoniste'
                })
              }}"
            >
              Voir le profil
            </a>
            <span class="badge bg-success mt-2">Déjà confirmé</span>
            {% endif %} {% else %}
            <a
              class="btn btn-dark mt-auto"
              href="{{
                path('app_orthophoniste_show', {
                  id: orthophoniste.id,
                  origin: 'IndexOrthophoniste'
                })
              }}"
            >
              Voir le profil
            </a>
            <a
              href="{{
                path('selectionner_orthophoniste', { id: orthophoniste.id })
              }}"
              class="btn btn-success mt-2"
            >
              Choisir
            </a>
            {% endif %} {% else %}
            <a
              class="btn btn-dark mt-auto"
              href="{{
                path('app_orthophoniste_show', {
                  id: orthophoniste.id,
                  origin: 'IndexOrthophoniste'
                })
              }}"
            >
              Voir le profil
            </a>
            {% endif %}
          </div>
        </div>
      </div>
    </div>
    {% else %}
    <div class="col-12 text-center text-muted">
      <em>Aucun orthophoniste trouvé.</em>
    </div>
    {% endfor %}
  </div>

  <!-- Pagination -->
  <div class="d-flex justify-content-center mt-4">
    {{ knp_pagination_render(orthophonistes) }}
  </div>

  {% if is_granted('ROLE_ADMIN') %}
  <a href="{{ path('app_administrateur') }}" class="btn btn-primary">Retour</a>
  {% elseif is_granted('ROLE_ORTHO') %}
  <a href="{{ path('app_orthophoniste') }}" class="btn btn-primary">Retour</a>
  {% elseif is_granted('ROLE_PATIENT') %}
  <a href="{{ path('app_patient') }}" class="btn btn-primary">Retour</a>
  {% else %}
  <a href="{{ path('app_default') }}" class="btn btn-danger">Retour</a>
  {% endif %}
</div>
{% endblock %}
