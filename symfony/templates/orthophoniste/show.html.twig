{% extends 'base.html.twig' %} {% block title %}Détails de l'orthophoniste {%
endblock %} {% block body %}
<div class="container mt-5">
  <div class="card shadow-sm p-4">
    <div class="text-center">
      {% if orthophoniste.imagesOrthophoniste is not empty %}
      <img
        src="{{ asset('uploads/images/' ~ orthophoniste.imagesOrthophoniste[0].name) }}"
        alt="Image de {{ orthophoniste.nom }}"
        class="rounded-circle img-thumbnail"
        style="width: 150px; height: 150px; object-fit: cover"
      />
      {% else %}
      <img
        src="{{ asset('uploads/images/default-user.png') }}"
        alt="Image par défaut"
        class="rounded-circle img-thumbnail"
        style="width: 150px; height: 150px; object-fit: cover"
      />
      {% endif %}
      <h2 class="mt-3">{{ orthophoniste.nom }} {{ orthophoniste.prenom }}</h2>
      <p class="text-muted">
        <u>{{ orthophoniste.specialisation.label }}</u>
      </p>
    </div>
    <hr />
    <div class="row">
      <div class="col-md-6">
        <p>
          <strong>Cabinet :</strong>
          {% if is_granted('ROLE_ORTHO') %}
          <a
            href="{{
              path('app_cabinet_orthophoniste', {
                id: orthophoniste.cabinet.id
              })
            }}"
            >{{ orthophoniste.cabinet.nom }}</a
          >
          {% elseif is_granted('ROLE_PATIENT') %}
          <a
            href="{{
              path('app_cabinet_show', {
                id: orthophoniste.cabinet.id,
                origin: 'ShowCabinet'
              })
            }}"
            >{{ orthophoniste.cabinet.nom }}</a
          >
          {% else %}
          {{ orthophoniste.cabinet.nom }}
          {% endif %}
        </p>
        <p>
          <strong>Ville :</strong>
          {{ orthophoniste.ville }}
        </p>
        <p>
          <strong>Email :</strong>
          {{ orthophoniste.email }}
        </p>
        <p>
          <strong>Téléphone :</strong>
          {{ orthophoniste.telephone }}
        </p>
      </div>
      <div class="col-md-6">
        <p>
          <strong>Genre :</strong>
          {{ orthophoniste.genre }}
        </p>
        <p>
          <strong>Date de naissance :</strong>
          {{ orthophoniste.createdAt | date('d/m/Y') }}
        </p>
        <p>
          <strong>Rôle :</strong>
          {% for role in orthophoniste.roles %} {% if role == 'ROLE_ORTHO' %}
          Orthophoniste {% elseif role == 'ROLE_USER' %} Utilisateur {% else %}
          {{ role }}
          {% endif %} {% endfor %}
        </p>
        <p>
          <strong>Nombre de patients :</strong>
          {{ orthophoniste.patients | length }}
        </p>
      </div>
    </div>
    <div class="text-center mt-4">
      <div class="d-flex justify-content-center gap-3">
        {% if app.request.get('origin') == 'IndexOrthophoniste' %}
        <a href="{{ path('app_orthophoniste') }}" class="btn btn-primary"
          >Retour</a
        >
        {% else %} {% if patient is not null %}
        <a
          href="{{ path('app_patient_show', { id: patient.id }) }}"
          class="btn btn-primary"
          >Retour</a
        >
        {% else %}
        <span>No patient available</span>
        {% endif %} {% endif %} {% if is_granted('ROLE_ADMIN') %}
        <a
          href="{{ path('app_orthophoniste_edit', { id: orthophoniste.id }) }}"
          class="btn btn-warning"
          >Modifier</a
        >
        {{
          include("orthophoniste/delete.html.twig", {
            orthophonistes: orthophoniste
          })
        }}
        {% endif %} {% if is_granted('ROLE_PATIENT') %} {% if patient is not
        null and patient.choixOrtho is not null %}
        <form
          method="post"
          action="{{
            path('app_orthophoniste_remove_patient', { id: orthophoniste.id })
          }}"
          onsubmit="return confirm('Êtes-vous sûr de vouloir arrêter le suivi de ce patient ?');"
        >
          <input
            type="hidden"
            name="_token"
            value="{{ csrf_token('remove_patient' ~ orthophoniste.id) }}"
          />
          <button type="submit" class="btn btn-danger">Arrêter le suivi</button>
        </form>
        {% else %}
        <a
          href="{{
            path('selectionner_orthophoniste', { id: orthophoniste.id })
          }}"
          class="btn btn-success"
          >Choisir</a
        >
        {% endif %} {% endif %}
      </div>
    </div>
  </div>
</div>
{% endblock %}
