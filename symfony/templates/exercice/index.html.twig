{% extends 'base.html.twig' %}

{% block title %}
Liste des Exercices
{% endblock %}

{% block body %}
<div class="container mt-4">
    <h1 class="text-center mb-4">Liste des Exercices</h1>

    {% if is_granted('ROLE_ORTHO') %}
    <div class="d-flex justify-content-between mb-3">
        <div>
            {% set currentRoute = app.request.get('_route') %}
            {% if currentRoute in ['app_exercice_type_vocabulaire', 'app_exercice_type_orthographe',
            'app_exercice_type_memoire', 'app_espace_orthophoniste_exercices_patient'] %}
            <a href="{{ path('app_exercice') }}" class="btn btn-dark">Tous les Exercices</a>
            {% endif %}
        </div>

        <div>
            <a href="{{ path('app_exercice_new') }}" class="btn btn-success me-2">Ajouter un exercice</a>
            <a href="{{ path('app_signification_new', {'origin': 'AddSignification'}) }}"
                class="btn btn-outline-success">Ajouter des Significations</a>
        </div>
    </div>
    {% endif %}

    {#
    <hr>

    <div class="mb-3">
        <a href="{{ path('app_exercice_type_vocabulaire') }}" class="btn btn-primary me-2">Vocabulaire</a>
        <a href="{{ path('app_exercice_type_orthographe') }}" class="btn btn-primary me-2">Orthographe</a>
        <a href="{{ path('app_exercice_type_memoire') }}" class="btn btn-primary">Mémoire</a>
    </div> #}

    <br>

    <table class="table table-striped table-bordered table-hover">
        <thead class="table-dark">
            <tr>
                <th>ID</th>
                <th>Exercices</th>
                <th>Chronomètre</th>
                <th>Score</th>
                {% if not is_granted('ROLE_ORTHO') %}
                <th>Orthophoniste</th>
                {% endif %}
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            {% for patientId, exercices in exercicesParPatient %}
            <tr>
                <td colspan="6" class="fw-bold"><a href="{{path('app_patient_show' , {'id': exercices[0].patient.id})}}"
                        class="text-decoration-none text-dark">Patient : <u>{{
                            exercices[0].patient.nom ~ ' ' ~
                            exercices[0].patient.prenom }}</u></a></td>
            </tr>

            {% for exercice in exercices %}
            <tr>
                <td>{{ exercice.id }}</td>
                <td>{{ exercice.type }}</td>
                <td>{{ exercice.chronometre is not null ? exercice.chronometre ~ ' sec' : 'N/A' }}</td>
                <td>
                    {% if scores[exercice.id] is defined and scores[exercice.id] is not empty %}
                    {% for score in scores[exercice.id] %}
                    <span class="badge 
                                {% if score.score >= 80 %} bg-success
                                {% elseif score.score >= 50 %} bg-warning
                                {% else %} bg-danger
                                {% endif %}
                                me-2">{{ score.score }}</span>
                    {% endfor %}
                    {% else %}
                    Non défini
                    {% endif %}
                    <div class="mt-2">
                        <strong>Moyenne :</strong>
                        {% set scoreValues = scores[exercice.id] is defined ? scores[exercice.id] | map(score =>
                        score.score) : [] %}
                        {% if scoreValues|length > 0 %}
                        {% set total = 0 %}
                        {% for score in scoreValues %}
                        {% set total = total + score %}
                        {% endfor %}
                        {{ (total / scoreValues|length) | round(2) }}
                        {% else %}
                        Non défini
                        {% endif %}
                    </div>
                </td>
                {% if not is_granted('ROLE_ORTHO') %}
                <td>{{ exercice.orthophoniste.nom ~ ' ' ~ exercice.orthophoniste.prenom }}</td>
                {% endif %}
                <td>
                    <a href="{{ path('app_exercice_show', { id: exercice.id }) }}" class="btn btn-primary btn-sm"
                        aria-label="Voir l'exercice {{ exercice.id }}">Voir</a>
                </td>
            </tr>
            {% endfor %}
            {% endfor %}
        </tbody>
    </table>

    <br>

    {% if is_granted('ROLE_ORTHO') %}
    <a href="{{path('app_espace_orthophoniste')}}" class="btn btn-outline-primary">Retour</a>
    {% if app.request.get('_route') == 'app_espace_orthophoniste_exercices_patient' %}
    <a href="{{path('app_espace_orthophoniste_patient', {'origin': 'ExercicePatient'})}}"
        class="btn btn-outline-primary">Liste des
        Patients</a>
    {% elseif app.request.get('_route') in ['app_exercice_type_vocabulaire', 'app_exercice_type_orthographe',
    'app_exercice_type_memoire'] %}
    <a href="{{path('app_exercice_type')}}" class="btn btn-outline-primary">Liste de Types Exercices</a>
    {% endif %}
    {% set origin = app.request.query.get('origin') %}
    {% if origin == 'TousExercices' %}
    <a href="{{path('app_espace_orthophoniste_choix')}}" class="btn btn-outline-primary">Catégorie des Exercices</a>
    {% endif %}
    {% endif %}

</div>
{% endblock %}