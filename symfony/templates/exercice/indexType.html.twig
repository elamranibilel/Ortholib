{% extends "base.html.twig" %}
{% block title %}Listes des Types Exercices{% endblock %}

{% block body %}
<h1>Listes des Types Exercices</h1>
<div class="container px-4 px-lg-5 mt-5">
    <div class="row gx-4 gx-lg-5 row-cols-1 row-cols-md-2 row-cols-lg-4 justify-content-center">
        <div class="col mb-4">
            <a href="{{path('app_exercice_type_vocabulaire')}}" class="text-decoration-none">
                <div class="card h-100 shadow-lg border-0 rounded-3 overflow-hidden">
                    <div class="position-relative" style="height: 200px; background-color: #f8f9fa;">
                        <img src="{{ asset('uploads/images/vocabulaire.jpg') }}" alt="Type Vocabulaire"
                            class="img-fluid w-100 h-100" style="object-fit: cover;">
                        <div
                            class="overlay position-absolute top-0 start-0 w-100 h-100 bg-dark bg-opacity-50 d-flex justify-content-center align-items-center opacity-0 transition-opacity">
                            <h5 class="text-white fw-bold">Voir les exercices</h5>
                        </div>
                    </div>
                    <div class="card-body text-center">
                        <h5 class="fw-bolder text-dark">Vocabulaire</h5>
                    </div>
                </div>
            </a>
        </div>
        <div class="col mb-4">
            <a href="{{path('app_exercice_type_orthographe')}}" class="text-decoration-none">
                <div class="card h-100 shadow-lg border-0 rounded-3 overflow-hidden">
                    <div class="position-relative" style="height: 200px; background-color: #f8f9fa;">
                        <img src="{{ asset('uploads/images/orthographe.jpg') }}" alt="Type Orthographe"
                            class="img-fluid w-100 h-100" style="object-fit: cover;">
                        <div
                            class="overlay position-absolute top-0 start-0 w-100 h-100 bg-dark bg-opacity-50 d-flex justify-content-center align-items-center opacity-0 transition-opacity">
                            <h5 class="text-white fw-bold">Voir les exercices</h5>
                        </div>
                    </div>
                    <div class="card-body text-center">
                        <h5 class="fw-bolder text-dark">Orthographe</h5>
                    </div>
                </div>
            </a>
        </div>
        <div class="col mb-4">
            <a href="{{path('app_exercice_type_memoire')}}" class="text-decoration-none">
                <div class="card h-100 shadow-lg border-0 rounded-3 overflow-hidden">
                    <div class="position-relative" style="height: 200px; background-color: #f8f9fa;">
                        <img src="{{ asset('uploads/images/memoire.webp') }}" alt="Type Mémoire"
                            class="img-fluid w-100 h-100" style="object-fit: cover;">
                        <div
                            class="overlay position-absolute top-0 start-0 w-100 h-100 bg-dark bg-opacity-50 d-flex justify-content-center align-items-center opacity-0 transition-opacity">
                            <h5 class="text-white fw-bold">Voir les exercices</h5>
                        </div>
                    </div>
                    <div class="card-body text-center">
                        <h5 class="fw-bolder text-dark">Mémoire</h5>
                    </div>
                </div>
            </a>
        </div>
        <div class="col mb-4">
            <a href="{{path('app_espace_orthophoniste_choix')}}" class="text-decoration-none">
                <div class="card h-100 shadow-lg border-0 rounded-3 overflow-hidden">
                    <div class="position-relative" style="height: 200px; background-color: #f8f9fa;">
                        <img src="{{ asset('uploads/images/sortie.png') }}" alt="Retour" class="img-fluid w-75 h-115"
                            style="object-fit: cover;">
                        <div
                            class="overlay position-absolute top-0 start-0 w-100 h-100 bg-dark bg-opacity-50 d-flex justify-content-center align-items-center opacity-0 transition-opacity">
                            <h5 class="text-white fw-bold">Retour</h5>
                        </div>
                    </div>
                    <div class="card-body text-center">
                        <h5 class="fw-bolder text-dark">Retour </h5>
                    </div>
                </div>
            </a>
        </div>
    </div>
</div>
{% endblock %}