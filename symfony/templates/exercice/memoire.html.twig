{% extends 'base.html.twig' %}
{% block title %}
    Exercice de mémoire
{% endblock %}
{% block body %}
    <h1>
        Exercice de mémoire
    </h1>
    {% if dernierScore is not null %}
        <p>
            Votre dernier score :
            {{ dernierScore }}
            /4
        </p>
    {% endif %}
    <p>
        Trouvez les 4 paires correspondantes.
    </p>
    <form method="post" id="memoire-form">
        <div class="cartes-container">
            {% for carte in cartes %}
                <div class="carte" data-type="{{ carte.type }}" data-valeur="{{ carte.valeur }}">
                    <span class="contenu-cache">
                        {{ carte.valeur }}
                    </span>
                </div>
            {% endfor %}
        </div>
        <input type="hidden" name="paires" id="paires-input">
            <button type="submit" class="btn btn-primary">
                Valider
            </button>
        </form>
        <script>
        document.addEventListener('DOMContentLoaded', () => {
            let cartesSelectionnees = [];
            let paires = [];

            document.querySelectorAll('.carte').forEach(carte => {
                carte.addEventListener('click', () => {
                    if (cartesSelectionnees.length < 2 && !carte.classList.contains('trouve')) {
                        carte.classList.add('visible');
                        cartesSelectionnees.push(carte);

                        if (cartesSelectionnees.length === 2) {
                            let type1 = cartesSelectionnees[0].dataset.type;
                            let valeur1 = cartesSelectionnees[0].dataset.valeur;
                            let type2 = cartesSelectionnees[1].dataset.type;
                            let valeur2 = cartesSelectionnees[1].dataset.valeur;

                            if (type1 !== type2 && valeur1 === valeur2) {
                                // Bonne paire
                                cartesSelectionnees.forEach(c => c.classList.add('trouve'));
                                paires.push({ mot: valeur1, image: valeur2 });
                            } else {
                                // Mauvaise paire
                                setTimeout(() => {
                                    cartesSelectionnees.forEach(c => c.classList.remove('visible'));
                                }, 1000);
                            }
                            cartesSelectionnees = [];
                        }
                    }
                });
            });

            document.getElementById('memoire-form').addEventListener('submit', (e) => {
                e.preventDefault();
                document.getElementById('paires-input').value = JSON.stringify(paires);
                e.target.submit();
            });
        });
    </script>
        <style>
        .cartes-container {
            display: flex;
            flex-wrap: wrap;
            gap: 10px;
            justify-content: center;
        }

        .carte {
            width: 100px;
            height: 100px;
            background: #ccc;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 20px;
            cursor: pointer;
            border-radius: 10px;
            user-select: none;
        }

        .carte .contenu-cache {
            display: none;
        }

        .carte.visible .contenu-cache {
            display: block;
        }

        .carte.trouve {
            background: lightgreen;
            cursor: default;
        }
    </style>
    {% endblock %}
    