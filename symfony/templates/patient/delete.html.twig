<form action="{{ path('app_patient_delete', {'id': patient.id}) }}" 
      onclick="event.stopPropagation();" 
      method="POST" 
      onsubmit="return confirm('Êtes-vous sûr de vouloir supprimer cet patient ?');" 
      style="display: inline;">
    <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ patient.id) }}">
    <button class="btn btn-danger btn-sm rounded" type="submit">Supprimer</button>
</form>
