{% extends 'base.html.twig' %}

{% block title %}Edit Signification{% endblock %}

{% block body %}
<h1 class="text-center mb-4 text-primary">Modification Signification</h1>

<div class="container">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card shadow-lg rounded-lg">
                <div class="card-body p-4">
                    {% form_theme form 'bootstrap_4_layout.html.twig' %}

                    {{ form_start(form) }}
                    {{ form_widget(form) }}

                    <div class="d-flex justify-content-center gap-3 flex-wrap mt-4">
                        <a href="{{ path('app_signification_index') }}"
                            class="btn btn-outline-primary rounded-pill px-4">
                            Retour
                        </a>
                        <button type="submit" class="btn btn-success rounded-pill px-4">
                            {{ button_label|default('Update') }}
                        </button>
                        {{ include('signification/_delete_form.html.twig') }}
                    </div>
                    {{ form_end(form) }}
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}