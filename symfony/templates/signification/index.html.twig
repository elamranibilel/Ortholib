{% extends 'base.html.twig' %}

{% block title %}
Significations
{% endblock %}

{% block body %}
<div class="container mt-4">
    <h1 class="mb-4 text-dark">
        Liste des Significations
    </h1>
    <div class="d-flex justify-content-end mb-3">
        <a href="{{ path('app_signification_new') }}" class="btn btn-success">
            + Ajouter une nouvelle signification
        </a>
    </div>
    <div class="table-responsive">
        <table class="table table-striped table-bordered">
            <thead class="table-dark">
                <tr>
                    <th>ID</th>
                    <th>Mot</th>
                    <th>Définition</th>
                    <th>Exercice N°</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                {% for signification in significations %}
                <tr>
                    <td>{{ signification.id }}</td>
                    <td>{{ signification.mots }}</td>
                    <td>{{ signification.definition }}</td>
                    <td>
                        {% if signification.exercices is not empty %}
                        {% for exercice in signification.exercices %}
                        <span class="badge bg-dark px-2 py-1">
                            #{{ exercice.id }} - {{ exercice.type }}
                        </span>
                        {% endfor %}
                        {% else %}
                        <span class="badge bg-secondary px-2 py-1">
                            Aucun exercice associé
                        </span>
                        {% endif %}
                    </td>
                    <td class="d-flex justify-content-between gap-3">
                        <a href="{{ path('app_signification_show', {'id': signification.id}) }}"
                            class="btn btn-primary btn-sm">
                            Voir
                        </a>
                        <a href="{{ path('app_signification_edit', {'id': signification.id}) }}"
                            class="btn btn-warning btn-sm">
                            Modifier
                        </a>
                    </td>
                </tr>
                {% else %}
                <tr>
                    <td colspan="5" class="text-center">
                        Aucune signification trouvée.
                    </td>
                </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>

    {% if app.request.get('origin') == 'SignificationOrtho' %}
    <a href="{{path('app_espace_orthophoniste')}}" class="btn btn-outline-primary">Retour</a>
    {% endif %}
</div>

<style>
    /* Ajout de marges entre les badges pour un affichage propre */
    .badge {
        font-size: 0.85rem;
        margin-right: 5px;
    }
</style>

{% endblock %}