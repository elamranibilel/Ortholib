<form method="post" action="{{ path('app_signification_delete', {'id': signification.id}) }}"
    onsubmit="return confirm('Are you sure you want to delete this item?');">
    <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ signification.id) }}">
    <button class="btn btn-danger rounded-pill px-4">Supprimer</button>
</form>