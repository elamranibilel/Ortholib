{% extends 'base.html.twig' %}
{% block title %}
	Liste des utilisateurs
{% endblock %}
{% block body %}
	<div class="container mt-5">
		<div class="d-flex justify-content-between align-items-center mb-4">
			<h1 class="text-primary">
				Gestion des utilisateurs
			</h1>
			<a href="{{ path('app_user_new') }}" class="btn btn-success">
				<i class="bi bi-plus-circle"></i>
				Ajouter un utilisateur
			</a>
		</div>
		<!-- Table des utilisateurs -->
		<div class="table-responsive">
			<table class="table table-striped table-hover align-middle">
				<thead class="table-dark">
					<tr>
						<th>
							<a href="{{ path('app_user_trie_id') }}" class="text-white text-decoration-none">
								ID
							</a>
						</th>
						<th>
							<a href="{{ path('app_user_trie_nom') }}" class="text-white text-decoration-none">
								Nom
							</a>
						</th>
						<th>
							{# <a href="{{ path('app_user_sort', {'field': 'email'}) }}"
							                            class="text-white text-decoration-none"> #}
							Email
							{# </a> #}
						</th>
						<th>
							{# <a href="{{ path('app_user_sort', {'field': 'ville'}) }}"
							                            class="text-white text-decoration-none"> #}
							Ville
							{# </a> #}
						</th>
						<th>
							{# <a href="{{ path('app_user_sort', {'field': 'ville'}) }}"
							                            class="text-white text-decoration-none"> #}
							Role
							{# </a> #}
						</th>
						<th class="text-center">
							Actions
						</th>
					</tr>
				</thead>
				<tbody>
					{% for user in users %}
						<tr style="cursor: pointer;" data-href="{{ path('app_user_show', {'id': user.id}) }}">
							<td>
								{{ user.id }}
							</td>
							<td>
								{# <a href="{{ path('app_user_search', {'field': 'nom', 'value': user.nom}) }}"
								                                class="text-body text-decoration-none" onclick="event.stopPropagation();"> #}
								{{ user.nom }}
								{# </a> #}
							</td>
							<td>
								{{ user.email }}
							</td>
							<td>
								{{ user.ville }}
							</td>
							<td>
								{% for role in user.roles %}
									{% if role == 'ROLE_USER' %}
										Utilisateur
									{% elseif role == 'ROLE_PATIENT' %}
										Patient
									{% elseif role == 'ROLE_ORTHO' %}
										Orthophoniste
									{% elseif role == 'ROLE_ADMIN' %}
										Administrateur
									{% else %}
										{{ role }}
									{% endif %}
								{% endfor %}
							</td>
							<td class="text-center">
								<div class="btn-group">
									<a href="{{ path('app_user_show', {'id': user.id}) }}" class="btn btn-info btn-sm me-2 rounded" onclick="event.stopPropagation();">
										Voir
									</a>
									<a href="{{ path('app_user_edit', {'id': user.id}) }}" class="btn btn-warning btn-sm me-2 rounded" onclick="event.stopPropagation();">
										Modifier
									</a>
									{{ include('user/delete.html.twig', { user: user }) }}
								</div>
							</td>
						</tr>
					{% else %}
						<tr>
							<td colspan="5" class="text-center text-muted">
								<em>
									Aucun utilisateur trouvé.
								</em>
							</td>
						</tr>
					{% endfor %}
				</tbody>
			</table>
		</div>
		<!-- Pagination -->
		<div class="d-flex justify-content-center mt-4">
			{{ knp_pagination_render(users) }}
		</div>
	</div>
{% endblock %}
