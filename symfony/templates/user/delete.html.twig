<form action="{{ path('app_user_delete', {'id': user.id}) }}" onclick="event.stopPropagation();" method="POST"
    onsubmit="return confirm('Êtes-vous sûr de vouloir supprimer ce utilisateur ?');">
    <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ user.id) }}" class="btn btn-danger">
    <button class="btn btn-danger" type="submit">Supprimer</button>
</form>