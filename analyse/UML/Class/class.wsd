@startuml Class

abstract class Utilisateur {
    - nom : String
    - prenom : String
    - email : String
    - motDePasse : String
    - telephone : String
    - dateNaissance : Date
    - genre : String
    - ville : String
    - statutCompte : String
    - dateInscription : Date
    

    + getNom() : String
    + setNom(nom : String)
    + getPrenom() : String
    + setPrenom(prenom : String)
    + getEmail() : String
    + setEmail(email : String)
    + getMotDePasse() : String
    + setMotDePasse(motDePasse : String)
    + getTelephone() : String
    + setTelephone(telephone : String)
    + getDateNaissance() : Date
    + setDateNaissance(dateNaissance : Date)
    + getGenre() : String
    + setGenre(genre : String)
    + getVille() : String
    + setVille(ville : String)
    + getStatutCompte() : String
    + setStatutCompte(statutCompte : String)
    + getDateInscription() : Date
    + setDateInscription(dateInscription : Date)
}

class Orthophoniste {
    - nombreHeuresTravail : int
    - listePatients : Patient

    + getNombreHeuresTravail() : int
    + setNombreHeuresTravail(nombreHeures : int)
    + getListePatients() : Patient
    + setListePatients(listePatients : Patient)
}

class Patient {
    - niveauLangue : String
    - difficulteTest : String
    - difficultesRencontrees : String
    - niveauApprentissage : String
    - maladie : String
    - preferencePresence : Boolean
    - preferenceCommunication : String
    - codeVerification : String
    - orthophonistesAssocies : Orthophoniste

    + getNiveauLangue() : String
    + setNiveauLangue(niveauLangue : String)
    + getDifficulteTest() : String
    + setDifficulteTest(difficulteTest : String)
    + getDifficultesRencontrees() : String
    + setDifficultesRencontrees(difficultesRencontrees : String)
    + getNiveauApprentissage() : String
    + setNiveauApprentissage(niveauApprentissage : String)
    + getMaladie() : String
    + setMaladie(maladie : String)
    + getDifficultes() : String
    + setDifficultes(difficultes : String)
    + getPreferencePresence() : Boolean
    + setPreferencePresence(preferencePresence : Boolean)
    + getPreferenceCommunication() : String
    + setPreferenceCommunication(preferenceCommunication : String)
    + getCodeVerification() : String
    + setCodeVerification(codeVerification : String)
    + getOrthophonistesAssocies() : Orthophoniste
    + setOrthophonistesAssocies(orthophonistesAssocies : Orthophoniste)
}

class Administrateur {
    - nom : String
    - prenom : String
    - email : String
    - motDePasse : String
    - statutCompte : String

    + getNom() : String
    + setNom(nom : String)
    + getPrenom() : String
    + setPrenom(prenom : String)
    + getEmail() : String
    + setEmail(email : String)
    + getMotDePasse() : String
    + setMotDePasse(motDePasse : String)
    + getStatutCompte() : String
    + setStatutCompte(statutCompte : String)
}

class Compte {
    - photo : String
    - informationPersonnel : Utilisateur
    - historiqueExercices : ExercicePersonnalise
    - historiqueJeux : Jeu
    + getPhoto() : String
    + setPhoto(photo : String)
    + getInformationPersonnel() : Utilisateur
    + setInformationPersonnel(informationPersonnel : Utilisateur)
    + getHistoriqueExercices() : ExercicePersonnalise
    + setHistoriqueExercices(historiqueExercices : ExercicePersonnalise)
    + getHistoriqueJeux() : Jeu
    + setHistoriqueJeux(historiqueJeux : Jeu)
}

class Jeu {
    - id : int
    - type : String
    - description : String
    - participants : Patient
    + getId() : int
    + setId(id : int)
    + getType() : String
    + setType(type : String)
    + getDescription() : String
    + setDescription(description : String)
    + getParticipants() : Patient
    + setParticipants(participants : Patient)
}

class ExercicePersonnalise {
    - id : int
    - contenu : String
    - patientAssocie : Patient
    - orthophonisteAssocie : Orthophoniste
    + getId() : int
    + setId(id : int)
    + getContenu() : String
    + setContenu(contenu : String)
    + getPatientAssocie() : Patient
    + setPatientAssocie(patientAssocie : Patient)
    + getOrthophonisteAssocie() : Orthophoniste
    + setOrthophonisteAssocie(orthophonisteAssocie : Orthophoniste)
}



Utilisateur <|-- Orthophoniste
Utilisateur <|-- Patient
Orthophoniste <|-- Administrateur 
Patient <|-- Administrateur 
Orthophoniste "1" -- "0..*" Patient : associe
Patient "0..*" -- "0..*" Jeu : participe
Patient "1" -- "0..*" ExercicePersonnalise : a
Compte "1" -- "0..*" ExercicePersonnalise : contient
Compte "1" -- "0..*" Jeu : contient
Compte "1" -- "1" Utilisateur : contient

@enduml
